# ==========================================
# Risk-Adjusted Scouting — Environment File
# ==========================================

# ---------------------------
# Paths
# ---------------------------

DB_PATH=db/scouting.duckdb
REPORTS_DIR=reports
ASSETS_DIR=assets

# ---------------------------
# Optimisation — Core
# ---------------------------

DEFAULT_LAMBDA=0.5
DEFAULT_BUDGET_18=600
DEFAULT_BUDGET_23=800
DEFAULT_K_SIGNINGS=3

# ---------------------------
# Financial Model
# ---------------------------

WAGE_RATIO=0.15
CONTRACT_YEARS=4
DISCOUNT_RATE=0.08

# ---------------------------
# Robust Optimisation (v2.0)
# ---------------------------

ROBUST_MODE=false
CVAR_ALPHA=0.1
N_SCENARIOS=200
SCENARIO_NOISE_STD=0.15

# ---------------------------
# Solver Settings
# ---------------------------

SOLVER_MAX_TIME=60
SOLVER_TOLERANCE=1e-6

# ---------------------------
# Filters
# ---------------------------

MIN_COST_MV=2.0
MIN_MINUTES=900
AGE_LOWER=18
AGE_UPPER=25
